# Primary provider (recommended for this submission)
LLM_PROVIDER=openai
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5-mini

# Azure OpenAI alternative. Uncomment and complete every value when used.
# LLM_PROVIDER=azure
# AZURE_OPENAI_API_KEY=replace_me
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
# AZURE_OPENAI_API_VERSION=replace_with_your_supported_version

# Retrieval and privacy controls
KNOWLEDGE_BASE_PATH=knowledge_base.txt
RETRIEVAL_MAX_RESULTS=5
RETRIEVAL_MIN_SCORE=0.15
RETRIEVAL_MIN_COVERAGE=0.40
ENABLE_TRACING=false
